---
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/CtaSection.astro';
---

<Layout
  title="書類ダウンロード | トラック運送事業者の人材不足・物価高騰対策支援補助金"
  description="支援補助金の各種申請書類（Word・Excel・PDF）をダウンロードできます。広島県トラック協会。"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="page-hero-label">書類ダウンロード</p>
        <h1 class="page-hero-title">各種申請書類</h1>
        <p class="page-hero-lead">
          申請するカテゴリーに応じた書類をダウンロードしてください。<br class="hidden sm:inline">すべての申請に「共通書類」が必要です。
        </p>
      </div>
    </div>
  </section>

  <section class="section--sm" style="background:var(--warm-50);padding:var(--space-2xl) 0">
    <div class="container">

      <!-- 交付要綱及び別表 -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">交付要綱及び別表</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">交付要綱</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/guidelines.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">別表（第1〜第4）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/appendix.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- 共通書類 -->
      <div class="download-group fade-up">
        <div class="card-header">
          <span style="display:inline-flex;align-items:center;background:var(--color-primary);color:#fff;font-size:var(--text-sm);font-weight:700;border-radius:var(--radius-full);padding:0 .85em;height:28px;white-space:nowrap;flex-shrink:0;">全ての申請に必要</span>
          <h2 class="download-group-title">共通書類</h2>
        </div>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">支援金交付申請書兼誓約書（別記様式第1号）</p>
                <p class="download-item-meta">すべての申請に必要</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/application.doc`} class="btn btn--sm btn--outline" target="_blank">Word</a>
              <a href={`${import.meta.env.BASE_URL}files/application.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ① DX推進 -->
      <div class="download-group fade-up">
        <div class="card-header">
          <div class="card-number">1</div>
          <h2 class="download-group-title">賃上げ原資の確保や生産性向上に必要なシステムの導入</h2>
        </div>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">システム導入計画書（別紙1）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex01.docx`} class="btn btn--sm btn--outline" target="_blank">Word</a>
              <a href={`${import.meta.env.BASE_URL}files/annex01.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">システム導入内訳書（別紙2）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex02.xlsx`} class="btn btn--sm btn--outline" target="_blank">Excel</a>
              <a href={`${import.meta.env.BASE_URL}files/annex02.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">システム導入証明書（別紙3）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex03.docx`} class="btn btn--sm btn--outline" target="_blank">Word</a>
              <a href={`${import.meta.env.BASE_URL}files/annex03.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ② 女性ドライバー環境整備 -->
      <div class="download-group fade-up">
        <div class="card-header">
          <div class="card-number">2</div>
          <h2 class="download-group-title">女性ドライバーの働きやすさにつながる施設・設備等の整備</h2>
        </div>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">施設・設備等の整備状況報告書（別紙4）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex04.docx`} class="btn btn--sm btn--outline" target="_blank">Word</a>
              <a href={`${import.meta.env.BASE_URL}files/annex04.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">施設・設備等の経費内訳書（別紙5）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex05.xlsx`} class="btn btn--sm btn--outline" target="_blank">Excel</a>
              <a href={`${import.meta.env.BASE_URL}files/annex05.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ③ 暑熱・寒冷対策 -->
      <div class="download-group fade-up">
        <div class="card-header">
          <div class="card-number">3</div>
          <h2 class="download-group-title">暑熱・寒冷対策を目的とした設備等の導入</h2>
        </div>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">設備導入等報告書（別紙6）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex06.docx`} class="btn btn--sm btn--outline" target="_blank">Word</a>
              <a href={`${import.meta.env.BASE_URL}files/annex06.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">設備導入等の経費内訳書（別紙7）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex07.xlsx`} class="btn btn--sm btn--outline" target="_blank">Excel</a>
              <a href={`${import.meta.env.BASE_URL}files/annex07.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ④ エコタイヤ -->
      <div class="download-group fade-up">
        <div class="card-header">
          <div class="card-number">4</div>
          <h2 class="download-group-title">エコタイヤ・再生タイヤの導入</h2>
        </div>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">エコタイヤ等導入内訳書（別紙8）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href={`${import.meta.env.BASE_URL}files/annex08.xlsx`} class="btn btn--sm btn--outline" target="_blank">Excel</a>
              <a href={`${import.meta.env.BASE_URL}files/annex08.pdf`} class="btn btn--sm btn--ghost" target="_blank">PDF</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <CtaSection />
</Layout>
