---
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/CtaSection.astro';
---

<Layout
  title="書類ダウンロード | トラック運送事業者の人材不足・物価高騰対策支援補助金"
  description="支援補助金の各種申請書類（Word・Excel・PDF）をダウンロードできます。広島県トラック協会。"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="page-hero-label">書類ダウンロード</p>
        <h1 class="page-hero-title">各種申請書類</h1>
        <p class="page-hero-lead">
          申請するカテゴリーに応じた書類をダウンロードしてください。
          すべての申請に「共通書類」が必要です。
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--warm-50)">
    <div class="container container--narrow">

      <div class="notice notice--info mb-2xl fade-up">
        <svg class="notice-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
        </svg>
        <div>
          ダウンロードリンクは準備でき次第公開します。ご質問は支援センター（082-232-3380）まで。
        </div>
      </div>

      <!-- 共通書類 -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">共通書類</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">支援金交付申請書兼誓約書（別記様式第1号）</p>
                <p class="download-item-meta">すべての申請に必要</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Word</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ① DX推進 -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">① DX推進</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">システム導入計画書（別紙1）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Word</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">システム導入内訳書（別紙2）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Excel</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">システム導入証明書（別紙3）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Word</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ② 女性ドライバー環境整備 -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">② 女性ドライバー環境整備</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">施設・設備等の整備状況報告書（別紙4）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Word</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">施設・設備等の経費内訳書（別紙5）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Excel</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ③ 暑熱・寒冷対策 -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">③ 暑熱・寒冷対策</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">設備導入等報告書（別紙6）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Word</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">設備導入等の経費内訳書（別紙7）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Excel</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ④ エンタイヤ -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">④ エンタイヤ</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">エンタイヤ等導入内訳書（別紙8）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Excel</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
        </div>
      </div>

      <!-- その他（交付完了後） -->
      <div class="download-group fade-up">
        <h2 class="download-group-title">その他（交付完了後）</h2>
        <div class="download-list">
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">財産処分承認申請書 / 財産処分報告書</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--outline">Word</a>
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
          <div class="download-item">
            <div class="download-item-info">
              <div class="download-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <p class="download-item-name">交付要綱（全文）</p>
              </div>
            </div>
            <div class="download-item-actions">
              <a href="#" class="btn btn--sm btn--ghost">PDF</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <CtaSection />
</Layout>
