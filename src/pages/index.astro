---
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/CtaSection.astro';
---

<Layout
  title="トラック運送事業者の人材不足・物価高騰対策支援補助金 | 広島県トラック協会"
  description="広島県内の中小トラック運送事業者を対象に、DX推進・職場環境整備・エコタイヤ導入等を支援。複数者連携型は最大3,000,000円。令和9年1月29日まで受付。"
>

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="container">
      <div class="hero-inner">
        <div>
<img
            src={`${import.meta.env.BASE_URL}title.svg`}
            alt="広島県トラック協会 人材不足・物価高騰対策支援補助金 支援金のご案内"
            class="hero-title-img hero-fade hero-fade--1"
            width="493"
            height="193"
          />
          <div class="hero-meta hero-fade hero-fade--2">
            <div class="hero-meta-item">
              <span class="hero-meta-label">受付期限</span>
              <span class="hero-meta-value">令和9年<span class="hl">1月29日</span>(金)</span>
            </div>
            <div class="hero-meta-group">
              <div class="hero-meta-item">
                <span class="hero-meta-label">最大支援額</span>
                <span class="hero-meta-value"><span class="hl">300</span>万円</span>
              </div>
              <div class="hero-meta-item hero-meta-item--last">
                <span class="hero-meta-label">補助率</span>
                <span class="hero-meta-value">最大 <span class="hl">2/3</span></span>
              </div>
            </div>
          </div>
          <div class="hero-actions hero-fade hero-fade--3">
            <a href={`${import.meta.env.BASE_URL}details/`} class="btn btn--primary btn--lg">支援内容を見る</a>
            <a href={`${import.meta.env.BASE_URL}application/`} class="btn btn--outline btn--lg">申請方法を確認</a>
          </div>
        </div>

        <div class="hero-visual hero-fade hero-fade--4">
          <img
            src={`${import.meta.env.BASE_URL}hero-image.svg`}
            alt="トラック運送事業者のイラスト"
            class="hero-truck-img"
            width="480"
            height="364"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- インフォメーションエリア -->
  <section class="info-section">
    <div class="container">
      <div class="info-inner">
        <span class="info-label">お知らせ</span>
        <ul class="info-list">
          <li class="info-item">
            <time class="info-date" datetime="2026-04-20">2026.4.20</time>
            <span class="info-text">トラック運送事業者の人手不足・物価高騰対策支援事業の特設ページを開設しました</span>
          </li>
          <li class="info-item">
            <time class="info-date" datetime="2026-04-20">2026.4.20</time>
            <a href={`${import.meta.env.BASE_URL}seminar/`} class="info-link">
              物流DX推進セミナーのご案内（支援金申請にはこのセミナーの受講が必要です。）
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </li>
          <li class="info-item">
            <time class="info-date" datetime="2026-04-20">2026.4.20</time>
            <a href={`${import.meta.env.BASE_URL}grantees/`} class="info-link">
              令和７年度トラック運送事業者の人手不足対策加速事業支援金交付対象事業者を公開しました
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 対象者 -->
  <section class="section" id="target">
    <div class="container">
      <div class="fade-up">
        <div class="heading-label">対象者</div>
        <h2 class="section-title" style="color:var(--color-primary)">広島県内に本社、支社、本店、支店又は営業所等を置く<br class="hidden sm:inline">中小トラック運送事業者</h2>
        <p style="font-weight:700;color:var(--navy-900);margin-top:var(--space-md)">●一般貨物自動車運送事業及び特定貨物自動車運送事業の営業許可を受けている者で、<br class="hidden sm:inline">資本金の額又は出資の総額が3億円以下又は常時使用する従業員の数が300人以下である事業者に限ります。</p>
      </div>
      <div class="fade-up" style="margin-top:var(--space-2xl);color:#DC2626">
        <p style="font-weight:700;font-size:1.1em;margin-bottom:var(--space-xs);display:flex;align-items:center;gap:var(--space-xs)">
          <svg viewBox="0 0 24 24" fill="#DC2626" style="width:20px;height:20px;flex-shrink:0">
            <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
          </svg>
          予算に達し次第終了します。
        </p>
        <p style="font-size:var(--text-sm)">支援金の申請受付は、申請順に行い、予算枠に達し次第申請受付を終了します。申請を検討の段階でも、概算申請予定額を支援センター（(082)232-3380）まで、お電話ください。</p>
      </div>
    </div>
  </section>

  <!-- 支援内容概要 -->
  <section class="section" id="support" style="background:var(--warm-50)">
    <div class="container">
      <div class="fade-up">
        <div class="heading-label">支援内容</div>
        <h2 class="section-title" style="color:var(--color-primary)">
          人材不足・物価高騰対策として、<br class="hidden sm:inline">以下の取り組みに対して支援金を交付します
        </h2>
        <p style="font-size:var(--text-sm);color:var(--color-text-secondary);margin-top:var(--space-sm)">※令和８年４月１日以降に契約・発注したものに限ります。</p>
      </div>
      <div class="card-grid mt-2xl stagger">
        <a href={`${import.meta.env.BASE_URL}details/#dx`} class="card fade-up">
          <div class="card-header">
            <div class="card-number">1</div>
            <h3 class="card-title">賃上げ原資の確保や生産性向上に必要なシステムの導入</h3>
          </div>
          <p class="card-desc">
            運賃管理・労働管理・運行管理等のDXシステム導入、デジタコ・自動運行・乗務構造可視化システム等。
          </p>
          <div class="card-amount-split">
            <div style="flex:1">
              <p style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);margin-bottom:2px">単独型（1者単独で導入）</p>
              <p style="font-family:var(--font-heading);font-size:var(--text-base);font-weight:700;color:var(--color-primary);line-height:1.2">最大<span class="card-amount-num" style="font-size:3em">1,000,000</span>円</p>
              <p style="font-size:var(--text-xs);color:var(--color-text-secondary);margin-top:10px"><span style="font-size:var(--text-lg);font-weight:900;color:#000">補助率 1/3</span>（車両50両以下の事業者に限る）</p>
            </div>
            <div class="card-amount-split-divider"></div>
            <div style="flex:1">
              <p style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);margin-bottom:2px">複数者連携型（グループで導入）</p>
              <p style="font-family:var(--font-heading);font-size:var(--text-base);font-weight:700;color:var(--color-primary);line-height:1.2">1事業者最大<span class="card-amount-num" style="font-size:3em">3,000,000</span>円</p>
              <p style="font-size:var(--text-xs);color:var(--color-text-secondary);margin-top:2px"><span style="font-size:var(--text-sm);font-weight:700;color:#000">補助率 2/3</span>　※51両以上の補助率は1/2</p>
            </div>
          </div>
          <span class="card-link">
            詳細を見る
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <a href={`${import.meta.env.BASE_URL}details/#women`} class="card fade-up">
          <div class="card-header">
            <div class="card-number">2</div>
            <h3 class="card-title">女性ドライバーの働きやすさにつながる施設・設備等の整備</h3>
          </div>
          <p class="card-desc">
            女性用トイレ・洗衣室・休憩室・シャワー室・ロッカーの新設、改修。今後採用予定の事業者も対象。
          </p>
          <div style="padding-top:var(--space-md);border-top:1px solid var(--warm-200)">
            <p style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);margin-bottom:2px">支援金額</p>
            <p style="font-family:var(--font-heading);font-size:var(--text-base);font-weight:700;color:var(--color-primary);line-height:1.2">最大<span class="card-amount-num" style="font-size:3em">3,000,000</span>円</p>
            <p style="font-size:var(--text-xs);color:var(--color-text-secondary);margin-top:10px"><span style="font-size:var(--text-lg);font-weight:900;color:#000">補助率 2/3</span></p>
          </div>
          <span class="card-link">
            詳細を見る
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <a href={`${import.meta.env.BASE_URL}details/#heat`} class="card fade-up">
          <div class="card-header">
            <div class="card-number">3</div>
            <h3 class="card-title">暑熱・寒冷対策を目的とした設備等の導入</h3>
          </div>
          <p class="card-desc">
            電動ファン付き作業着、ネッククーラー、スポットクーラー、ヒーター付き作業着、冷凍庫等。
          </p>
          <div style="padding-top:var(--space-md);border-top:1px solid var(--warm-200)">
            <p style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);margin-bottom:2px">支援金額</p>
            <p style="font-family:var(--font-heading);font-size:var(--text-base);font-weight:700;color:var(--color-primary);line-height:1.2">最大<span class="card-amount-num" style="font-size:3em">500,000</span>円</p>
            <p style="font-size:var(--text-xs);color:var(--color-text-secondary);margin-top:10px"><span style="font-size:var(--text-lg);font-weight:900;color:#000">補助率 2/3</span></p>
          </div>
          <span class="card-link">
            詳細を見る
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <a href={`${import.meta.env.BASE_URL}details/#tire`} class="card fade-up">
          <div class="card-header">
            <div class="card-number">4</div>
            <h3 class="card-title">エコタイヤ・再生タイヤの導入</h3>
          </div>
          <p class="card-desc">
            広島県トラック協会の「エコタイヤ・再生タイヤ助成対象商品一覧」に掲載されているエコタイヤまたは再生タイヤの導入経費。
          </p>
          <div class="card-amount-split">
            <div style="flex:1">
              <p style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);margin-bottom:2px">50両以下</p>
              <p style="font-family:var(--font-heading);font-size:var(--text-base);font-weight:700;color:var(--color-primary);line-height:1.2">最大<span class="card-amount-num" style="font-size:3em">400,000</span>円</p>
              <p style="font-size:var(--text-xs);color:var(--color-text-secondary);margin-top:10px"><span style="font-size:var(--text-lg);font-weight:900;color:#000">補助率 2/3</span></p>
            </div>
            <div class="card-amount-split-divider"></div>
            <div style="flex:1">
              <p style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);margin-bottom:2px">51両以上</p>
              <p style="font-family:var(--font-heading);font-size:var(--text-base);font-weight:700;color:var(--color-primary);line-height:1.2">最大<span class="card-amount-num" style="font-size:3em">600,000</span>円</p>
              <p style="font-size:var(--text-xs);color:var(--color-text-secondary);margin-top:10px"><span style="font-size:var(--text-lg);font-weight:900;color:#000">補助率 2/3</span></p>
            </div>
          </div>
          <span class="card-link">
            詳細を見る
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>

      <div class="text-center mt-2xl fade-up">
        <a href={`${import.meta.env.BASE_URL}details/`} class="btn btn--primary btn--lg">支援内容の詳細を見る</a>
      </div>
    </div>
  </section>

  <!-- 申請の流れ（簡略版） -->
  <section class="section">
    <div class="container">
      <div class="fade-up">
        <div class="heading-label">申請方法</div>
        <h2 class="section-title">申請から交付までの流れ</h2>
        <p class="section-subtitle">設備導入完了後に必要書類を提出してください。申請は導入後に行います。</p>
      </div>
      <div class="steps mt-2xl stagger">
        <div class="step fade-up">
          <div class="step-number">STEP1</div>
          <h3 class="step-title">事前相談</h3>
          <p class="step-desc">支援センターに電話で申請予定額（概算）をお伝えください。残予算の目安等をご案内します。</p>
        </div>
        <div class="step-arrow" aria-hidden="true"></div>
        <div class="step fade-up">
          <div class="step-number">STEP2</div>
          <h3 class="step-title">設備導入・整備</h3>
          <p class="step-desc">令和8年4月1日以降に対象の設備・システムを契約・発注し、導入を完了してください。</p>
        </div>
        <div class="step-arrow" aria-hidden="true"></div>
        <div class="step fade-up">
          <div class="step-number">STEP3</div>
          <h3 class="step-title">書類作成・提出</h3>
          <p class="step-desc">必要書類を揃え、支援センターへ郵送。令和9年1月29日必着。</p>
        </div>
        <div class="step-arrow" aria-hidden="true"></div>
        <div class="step fade-up">
          <div class="step-number">STEP4</div>
          <h3 class="step-title">審査・交付</h3>
          <p class="step-desc">申請内容を審査のうえ交付決定。口座振込にて支援金を交付します。</p>
        </div>
      </div>
      <div class="text-center mt-2xl fade-up">
        <a href={`${import.meta.env.BASE_URL}application/`} class="btn btn--outline btn--lg">申請方法の詳細を見る</a>
      </div>
    </div>
  </section>

  <CtaSection />
</Layout>

<!-- フローティングバナー（トップページのみ） -->
<div id="floating-banner" style="
  position:fixed;
  bottom:24px;
  right:24px;
  z-index:1000;
  opacity:0;
  transform:translateY(16px);
  transition:opacity .6s ease, transform .6s ease;
  pointer-events:none;
">
  <div style="position:relative;display:inline-block;">
    <a href={`${import.meta.env.BASE_URL}files/dx.pdf`} target="_blank" rel="noopener noreferrer" style="display:block;line-height:0;">
      <img
        src={`${import.meta.env.BASE_URL}bnr_dx.png`}
        alt="デジタル導入のご相談はこちら"
        width="240"
        class="floating-banner-img"
        style="display:block;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,.2);"
      />
    </a>
    <button
      id="floating-banner-close"
      aria-label="バナーを閉じる"
      style="
        position:absolute;
        top:-12px;
        right:-12px;
        background:none;
        border:none;
        padding:0;
        cursor:pointer;
        line-height:0;
      "
    >
      <img src={`${import.meta.env.BASE_URL}icon_close.svg`} alt="閉じる" width="36" height="36" />
    </button>
  </div>
</div>

<style>
  .floating-banner-img { width: 200px; transition: opacity .2s ease; }
  .floating-banner-img:hover { opacity: .8; }
  @media (min-width: 768px) { .floating-banner-img { width: 300px; } }
</style>

<script>
  (function () {
    const banner = document.getElementById('floating-banner');
    const closeBtn = document.getElementById('floating-banner-close');
    if (!banner || !closeBtn) return;

    // ヒーローアニメーション完了後（約2秒）にふわっと表示
    setTimeout(function () {
      banner.style.opacity = '1';
      banner.style.transform = 'translateY(0)';
      banner.style.pointerEvents = 'auto';
    }, 2000);

    closeBtn.addEventListener('click', function () {
      banner.style.opacity = '0';
      banner.style.transform = 'translateY(16px)';
      banner.style.pointerEvents = 'none';
    });
  })();
</script>
