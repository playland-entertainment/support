---
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/CtaSection.astro';
---

<Layout
  title="支援交付事業者一覧 | トラック運送事業者の人材不足・物価高騰対策支援補助金"
  description="支援補助金の交付が決定した事業者の一覧。単独型・複数者連携型ごとに掲載しています。広島県トラック協会。"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="page-hero-label">交付事業者</p>
        <h1 class="page-hero-title">令和７年度 支援交付事業者一覧</h1>
        <p class="page-hero-lead">
          支援補助金の交付が決定した事業者を掲載しています。
        </p>
      </div>
    </div>
  </section>

  <!-- 支援交付事業者一覧 -->
  <section class="section" style="padding-top:var(--space-xl)">
    <div class="container">

      <div class="fade-up" style="margin-bottom:var(--space-2xl)">
        <p style="font-weight:700;font-size:var(--text-sm);color:var(--color-text);margin-bottom:var(--space-sm)">
          令和７年度トラック運送事業者の人手不足対策加速事業支援金交付対象事業者一覧（五十音順／敬称略）
        </p>
        <p style="font-size:var(--text-sm);color:var(--color-text-secondary);line-height:1.8">
          令和７年度は、以下の140社が支援金を活用し、適正な運賃の収受、運送・荷役等の効率化など、<br>
          改正物流法への対応のためにシステムを導入しました。
        </p>
      </div>

