<section class="cta-section section">
  <div class="container">
    <div class="cta-inner fade-up">
      <div class="heading-label" style="justify-content:center">お問い合わせ</div>
      <h2 class="section-title">お気軽にご相談ください</h2>
      <p class="section-subtitle" style="margin:0 auto var(--space-lg)">
        申請方法がわからない、<br class="sm:hidden">対象になるか確認したい等、<br>お気軽にお問い合わせください。
      </p>
      <div class="cta-tel">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <a href="tel:082-232-3380" class="cta-tel-number">(082)232-3380</a>
      </div>
      <p class="cta-tel-hours" style="margin-bottom:var(--space-md)">受付時間：9:00〜17:00<br class="sm:hidden">（土日祝日・年末年始・お盆を除く）</p>
      <div class="cta-tel" style="margin-top:0">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 6 2 18 2 18 9"/>
          <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/>
          <rect x="6" y="14" width="12" height="8"/>
        </svg>
        <span class="cta-tel-number">(082)297-7751</span>
      </div>
      <div class="cta-tel" style="margin-top:var(--space-md)">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
