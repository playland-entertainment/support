---
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img src="/logo.svg" alt="広島県トラック協会 人材不足・物価高騰対策支援補助金" class="header-logo-img" width="auto" height="52" />
    </a>

    <nav class="header-nav">
      <ul>
        <li><a href="/" class:list={[{ active: isActive('/') }]}>ホーム</a></li>
        <li><a href="/support/" class:list={[{ active: isActive('/support') }]}>支援内容</a></li>
        <li><a href="/application/" class:list={[{ active: isActive('/application') }]}>申請方法</a></li>
        <li><a href="/download/" class:list={[{ active: isActive('/download') }]}>書類ダウンロード</a></li>
        <li><a href="/seminar/" class:list={[{ active: isActive('/seminar') }]}>セミナー案内</a></li>
        <li><a href="/faq/" class:list={[{ active: isActive('/faq') }]}>よくある質問</a></li>
      </ul>
    </nav>


<button class="menu-toggle" aria-label="メニュー">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<nav class="mobile-nav">
  <ul>
    <li><a href="/" class:list={[{ active: isActive('/') }]}>ホーム</a></li>
    <li><a href="/support/" class:list={[{ active: isActive('/support') }]}>支援内容</a></li>
    <li><a href="/application/" class:list={[{ active: isActive('/application') }]}>申請方法</a></li>
    <li><a href="/download/" class:list={[{ active: isActive('/download') }]}>書類ダウンロード</a></li>
    <li><a href="/seminar/" class:list={[{ active: isActive('/seminar') }]}>セミナー案内</a></li>
    <li><a href="/faq/" class:list={[{ active: isActive('/faq') }]}>よくある質問</a></li>
  </ul>
</nav>
