---
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <div class="logo-mark">
        <svg viewBox="0 0 24 24">
          <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9 1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" fill="white"/>
        </svg>
      </div>
      <div class="logo-text">
        <span class="logo-org">(公社)広島県トラック協会</span>
        <span class="logo-title">人材不足・物価高騰対策支援補助金</span>
      </div>
    </a>

    <nav class="header-nav">
      <ul>
        <li><a href="/" class:list={[{ active: isActive('/') }]}>ホーム</a></li>
        <li><a href="/support/" class:list={[{ active: isActive('/support') }]}>支援内容</a></li>
        <li><a href="/application/" class:list={[{ active: isActive('/application') }]}>申請方法</a></li>
        <li><a href="/download/" class:list={[{ active: isActive('/download') }]}>書類DL</a></li>
        <li><a href="/seminar/" class:list={[{ active: isActive('/seminar') }]}>セミナー</a></li>
        <li><a href="/faq/" class:list={[{ active: isActive('/faq') }]}>FAQ</a></li>
      </ul>
    </nav>

    <div class="header-cta">
      <a href="tel:082-232-3380" class="header-tel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        082-232-3380
      </a>
      <a href="/application/" class="btn btn--primary btn--sm">申請について</a>
    </div>

    <button class="menu-toggle" aria-label="メニュー">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<nav class="mobile-nav">
  <ul>
    <li><a href="/" class:list={[{ active: isActive('/') }]}>ホーム</a></li>
    <li><a href="/support/" class:list={[{ active: isActive('/support') }]}>支援内容</a></li>
    <li><a href="/application/" class:list={[{ active: isActive('/application') }]}>申請方法</a></li>
    <li><a href="/download/" class:list={[{ active: isActive('/download') }]}>書類DL</a></li>
    <li><a href="/seminar/" class:list={[{ active: isActive('/seminar') }]}>セミナー</a></li>
    <li><a href="/faq/" class:list={[{ active: isActive('/faq') }]}>FAQ</a></li>
  </ul>
  <div class="mobile-nav-cta">
    <a href="tel:082-232-3380" class="btn btn--primary btn--full">電話で相談する</a>
  </div>
</nav>
